# =========================================================================
#  Local secrets — NEVER commit this file. It is git-ignored.
#  Copy from `.env.example` and fill in real values.
# =========================================================================

# The EOA that will deploy. Use a dedicated burner wallet for testnets.
# Format: 0x + 64 hex chars (32 bytes). Fund it with a tiny amount of ETH.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Etherscan V2 API key for `--verify`. One key works for all
# Etherscan-family chains (Ethereum, Base, Base Sepolia, Arbitrum, etc.).
# Get one at https://etherscan.io/myapikey (the same key works on
# basescan.org — they share the Etherscan V2 unified API).
ETHERSCAN_API_KEY=YourApiKeyToken

# Optional: override default public RPCs. Defaults are public/uncertified.
# Recommended for prod: use Alchemy, QuickNode, or your own node.
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
